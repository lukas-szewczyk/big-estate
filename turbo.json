{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "API_SERVER_BASE_URL",
    "AUTH_COOKIE_DOMAIN",
    "AUTH_COOKIE_SECURE",
    "BOOTSTRAP_ADMIN_EMAIL",
    "BOOTSTRAP_ADMIN_PASSWORD",
    "DATABASE_URL",
    "FRONTEND_ORIGIN",
    "POSTGRES_DB",
    "POSTGRES_PASSWORD",
    "POSTGRES_PORT",
    "POSTGRES_USER",
    "PUBLIC_API_BASE_URL",
    "SITE_URL"
  ],
  "globalDependencies": ["pnpm-lock.yaml", "compose.yaml", ".env*", "**/.env*"],
  "tasks": {
    "bootstrap-admin": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "**/.env*"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "db-down": {
      "cache": false
    },
    "db-logs": {
      "cache": false,
      "persistent": true
    },
    "db-reset": {
      "cache": false
    },
    "db-up": {
      "cache": false
    },
    "deploy": {
      "cache": false,
      "dependsOn": ["build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "migrate": {
      "cache": false
    },
    "test": {}
  }
}
