# ==========================================
# Przykładowe wartości zmiennych
# Skopiuj do terraform.tfvars i wypełnij swoimi danymi
# ==========================================

# Domena główna
domain = "twojadomena.pl"

# Hetzner Cloud
# Token API: https://console.hetzner.cloud/projects → Security → API Tokens
# Alternatywnie ustaw zmienną środowiskową: TF_VAR_hcloud_token
hcloud_token = "TUTAJ_WKLEJ_TOKEN_HETZNER"

# Cloudflare
# Account ID: Dashboard → Workers & Pages → po prawej stronie
cf_account_id = "TUTAJ_WKLEJ_ACCOUNT_ID"

# Zone ID: Dashboard → strona domeny → po prawej stronie
cf_zone_id = "TUTAJ_WKLEJ_ZONE_ID"

# CLOUDFLARE_API_TOKEN — ustaw jako zmienną środowiskową (nie wpisuj tutaj)
# Token tworzymy w: Dashboard → My Profile → API Tokens
# Wymagane uprawnienia:
#   - Zone:DNS:Edit
#   - Zone:Zone Settings:Edit
#   - Account:Cloudflare Workers Scripts:Edit
