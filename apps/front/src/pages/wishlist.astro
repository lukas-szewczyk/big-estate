---
export const prerender = false;

import BaseHead from "../components/BaseHead.astro";
import { WishlistPage } from "../components/wishlist/WishlistPage";
import { getPublicApiBaseUrl, getSessionUser } from "../lib/auth";
import { fetchWishlists } from "../lib/server/wishlist";

const user = await getSessionUser(Astro.request, Astro.locals);
const wishlists = user ? await fetchWishlists(Astro.request, Astro.locals) : [];
const apiBaseUrl = getPublicApiBaseUrl(Astro.locals);
const accountHref = user ? "/dashboard" : "/login";
const addListingHref = user ? "/dashboard/oferty/nowa" : "/login";
---

<!doctype html>
<html lang="pl" class="h-full bg-background">
  <head>
    <BaseHead
      title="Wishlista ofert | LUNARIS"
      description="Zapisuj oferty nieruchomości, porządkuj je w wielu listach i wracaj do nich później."
      image="/listing-placeholder.svg"
    />
  </head>
  <body class="min-h-full bg-[#f7f3ed] text-[#171512]">
    <main class="relative min-h-screen overflow-hidden">
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
        <div
          class="absolute inset-0"
          style="background: radial-gradient(circle at top right, rgba(178, 146, 101, 0.17) 0%, rgba(248, 244, 238, 0) 34%), linear-gradient(180deg, #f8f4ee 0%, #f3eee5 100%);"
        ></div>
        <div class="absolute top-[-8rem] right-[-6rem] h-72 w-72 rounded-full bg-[#d8c3a8]/25 blur-3xl"></div>
        <div class="absolute bottom-[-10rem] left-[-6rem] h-80 w-80 rounded-full bg-[#e7dccb]/60 blur-3xl"></div>
      </div>

      <header class="relative z-10 px-5 pt-4 sm:px-8 sm:pt-7">
        <div class="mx-auto flex w-full max-w-[72rem] items-center justify-end gap-4">
          <a
            href={addListingHref}
            class="inline-flex h-11 items-center justify-center rounded-full border border-black/10 bg-[#19150f] px-4 whitespace-nowrap font-secondary text-sm font-medium text-white shadow-[0_10px_24px_rgba(35,28,19,0.08)] transition-all duration-200 hover:-translate-y-0.5 hover:bg-[#110e09]"
          >
            Dodaj ogłoszenie
          </a>

          <a
            href={accountHref}
            class="inline-flex h-11 items-center justify-center rounded-full border border-black/10 bg-white/65 px-4 whitespace-nowrap font-secondary text-sm font-medium text-[#2c261f] shadow-[0_10px_24px_rgba(35,28,19,0.05)] backdrop-blur transition-all duration-200 hover:-translate-y-0.5 hover:bg-white"
          >
            Moje konto
          </a>
        </div>
      </header>

      <section class="relative z-10 px-5 pb-8 pt-6 sm:px-8 sm:pb-10 sm:pt-10">
        <div class="mx-auto max-w-[72rem]">
          <div class="mb-6 max-w-3xl">
            <p class="font-primary text-[0.7rem] uppercase tracking-[0.28em] text-[#8a7760]">Wishlist</p>
            <h1 class="mt-3 font-secondary text-[2.3rem] font-semibold tracking-[-0.05em] text-[#17130f]">
              Zapisane oferty nieruchomości
            </h1>
            <p class="mt-4 font-secondary text-base text-[#665a4e]">
              Wracaj do mieszkań, domów i działek, które chcesz porównać lub pokazać bliskim.
            </p>
          </div>

          <WishlistPage
            apiBaseUrl={apiBaseUrl}
            client:load
            initialUser={user}
            initialWishlists={wishlists}
          />
        </div>
      </section>
    </main>
  </body>
</html>
