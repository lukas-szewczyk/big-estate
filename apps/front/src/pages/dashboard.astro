---
import "../styles/dashboard.css";
import Sidebar from "../components/dashboard/Sidebar.astro";
import StatCard from "../components/dashboard/StatCard.astro";
import RoverTable from "../components/dashboard/RoverTable.astro";
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Rover Command Center | LUNARIS</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Geist:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Sharp:opsz,wght,FILL,GRAD@24,100,0,0"
      rel="stylesheet"
    />
  </head>
  <body class="h-full bg-[var(--background)]">
    <div class="flex h-full w-full overflow-hidden">
      <!-- Sidebar -->
      <Sidebar />

      <!-- Main Content -->
      <main class="flex flex-col flex-1 h-full gap-6 p-8 overflow-auto bg-[var(--background)]">
        <!-- Header -->
        <div class="flex items-center justify-between gap-4 w-full">
          <div class="flex flex-col flex-1 gap-1">
            <h1 class="font-primary text-[var(--foreground)] text-[36px] leading-none font-semibold">Rover Command Center</h1>
            <p class="font-secondary text-[var(--muted-foreground)] text-[12px] leading-[1.5]">Monitor fleet readiness, utilization, and rental availability in real time.</p>
          </div>
          <div class="flex gap-3">
            <button class="flex items-center justify-center gap-[6px] h-[32px] px-4 rounded-full bg-[var(--background)] border border-[var(--border)]">
              <span class="font-primary text-[var(--foreground)] text-[11px] font-medium leading-none text-center">View Missions</span>
            </button>
            <button class="flex items-center justify-center gap-[6px] h-[32px] px-4 rounded-full bg-[var(--primary)]">
              <span class="font-primary text-[var(--primary-foreground)] text-[11px] font-medium leading-none text-center">Deploy Rover</span>
            </button>
          </div>
        </div>

        <!-- Stat Cards -->
        <div class="flex gap-4 w-full">
          <StatCard
            label="Active Rovers"
            value="18"
            description="4 currently deployed"
          />
          <StatCard
            label="Rental Utilization"
            value="82%"
            description="Up 5% vs last week"
            descriptionColor="var(--color-success-foreground)"
          />
          <StatCard
            label="Charge-ready"
            value="12"
            description="Fully charged spares"
          />
        </div>

        <!-- Rover Fleet Table -->
        <RoverTable />
      </main>
    </div>
  </body>
</html>
