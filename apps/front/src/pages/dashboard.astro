---
export const prerender = false;

import "../styles/global.css";
import Sidebar from "../components/dashboard/Sidebar.astro";
import StatCard from "../components/dashboard/StatCard.astro";
import RoverTable from "../components/dashboard/RoverTable.astro";
import { getPublicApiBaseUrl, getSessionUser } from "../lib/auth";

const authUser = await getSessionUser(Astro.request, Astro.locals);
if (!authUser) {
  return Astro.redirect("/login");
}

const apiBaseUrl = getPublicApiBaseUrl(Astro.locals);
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Rover Command Center | LUNARIS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Geist:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Sharp:opsz,wght,FILL,GRAD@24,100,0,0"
      rel="stylesheet"
    />
  </head>
  <body class="h-full bg-[var(--background)]">
    <div class="flex h-full w-full overflow-hidden">
      <Sidebar />

      <main class="flex h-full flex-1 flex-col gap-6 overflow-auto bg-[var(--background)] p-8">
        <div class="flex w-full flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
          <div class="flex flex-1 flex-col gap-3">
            <div class="inline-flex w-fit items-center gap-2 border border-[var(--border)] bg-[var(--card)] px-3 py-2">
              <span class="font-primary text-[11px] uppercase tracking-[0.18em] text-[var(--muted-foreground)]">Authenticated session</span>
              <span class="font-secondary text-xs text-[var(--secondary-foreground)]">{authUser.email} · {authUser.role}</span>
            </div>
            <div class="flex flex-col gap-1">
              <h1 class="font-primary text-[var(--foreground)] text-[36px] leading-none font-semibold">Rover Command Center</h1>
              <p class="font-secondary text-[12px] leading-[1.6] text-[var(--muted-foreground)]">Monitor fleet readiness, utilization, and rental availability in real time through a protected Axum-backed session.</p>
            </div>
          </div>

          <div class="flex flex-wrap gap-3">
            <button class="flex h-[32px] items-center justify-center gap-[6px] rounded-full border border-[var(--border)] bg-[var(--background)] px-4">
              <span class="font-primary text-center text-[11px] leading-none font-medium text-[var(--foreground)]">View Missions</span>
            </button>
            <button class="flex h-[32px] items-center justify-center gap-[6px] rounded-full bg-[var(--primary)] px-4">
              <span class="font-primary text-center text-[11px] leading-none font-medium text-[var(--primary-foreground)]">Deploy Rover</span>
            </button>
            <button
              class="flex h-[32px] items-center justify-center gap-[6px] rounded-full border border-[var(--border)] bg-[var(--card)] px-4"
              type="button"
              data-logout-button
            >
              <span class="font-primary text-center text-[11px] leading-none font-medium text-[var(--foreground)]">Sign out</span>
            </button>
          </div>
        </div>

        <div class="flex w-full gap-4 max-lg:flex-col">
          <StatCard label="Active Rovers" value="18" description="4 currently deployed" />
          <StatCard
            label="Rental Utilization"
            value="82%"
            description="Up 5% vs last week"
            descriptionColor="var(--color-success-foreground)"
          />
          <StatCard label="Charge-ready" value="12" description="Fully charged spares" />
        </div>

        <RoverTable />
      </main>
    </div>

    <script is:inline define:vars={{ apiBaseUrl }}>
      const logoutButton = document.querySelector("[data-logout-button]");

      logoutButton?.addEventListener("click", async () => {
        if (!(logoutButton instanceof HTMLButtonElement)) {
          return;
        }

        logoutButton.disabled = true;
        logoutButton.textContent = "Signing out...";

        try {
          await fetch(`${apiBaseUrl}/auth/logout`, {
            method: "POST",
            credentials: "include",
          });
        } finally {
          window.location.assign("/login");
        }
      });
    </script>
  </body>
</html>
