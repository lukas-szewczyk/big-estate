---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.homepage {
				width: min(980px, calc(100% - 2rem));
				margin: 2.5rem auto;
				padding: 1.5rem;
				border-radius: 8px;
				background: #fff;
				border: 1px solid rgba(var(--gray-light), 0.95);
			}

			.heading {
				margin-bottom: 1.5rem;
			}

			.heading h1 {
				font-size: 1.1rem;
				margin-bottom: 0.4rem;
			}

			.heading p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.85rem;
			}

			.filter-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 0.85rem 0.9rem;
				margin-bottom: 1.15rem;
			}

			.field {
				display: grid;
				gap: 0.35rem;
			}

			.field label {
				font-size: 0.7rem;
				color: rgb(var(--gray-dark));
				font-weight: 600;
			}

			.field input,
			.field select {
				height: 34px;
				width: 100%;
				border-radius: 6px;
				border: 1px solid rgb(var(--gray-light));
				background: #fff;
				padding: 0 0.7rem;
				font-size: 0.78rem;
				color: rgb(var(--gray-dark));
			}

			.field input::placeholder {
				color: rgb(var(--gray));
			}

			.quick-filters {
				display: flex;
				gap: 0.45rem;
				flex-wrap: wrap;
				margin-bottom: 1.2rem;
			}

			.pill {
				border: none;
				background: transparent;
				padding: 0;
				font-size: 0.72rem;
				font-weight: 600;
				color: rgb(var(--gray-dark));
				cursor: pointer;
			}

			.pill.active {
				color: rgb(var(--black));
				text-decoration: underline;
				text-underline-offset: 3px;
			}

			.footer-row {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.8rem;
				flex-wrap: wrap;
			}

			.toggles {
				display: flex;
				align-items: center;
				gap: 2.2rem;
				flex-wrap: wrap;
			}

			.toggle {
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
				font-size: 0.75rem;
				color: rgb(var(--gray-dark));
			}

			.toggle input {
				appearance: none;
				width: 26px;
				height: 16px;
				border-radius: 999px;
				background: #d8dbe2;
				position: relative;
				cursor: pointer;
				transition: background 140ms ease;
			}

			.toggle input::after {
				content: '';
				position: absolute;
				inset: 2px auto auto 2px;
				width: 12px;
				height: 12px;
				border-radius: 50%;
				background: #fff;
				transition: transform 140ms ease;
			}

			.toggle input:checked {
				background: #16181d;
			}

			.toggle input:checked::after {
				transform: translateX(10px);
			}

			.actions {
				display: inline-flex;
				gap: 0.45rem;
			}

			.actions button {
				height: 32px;
				border-radius: 6px;
				border: 1px solid rgb(var(--gray-light));
				padding: 0 0.85rem;
				font-size: 0.72rem;
				cursor: pointer;
			}

			.actions .primary {
				background: #16181d;
				color: #fff;
				border-color: #16181d;
			}

			.actions .secondary {
				background: #fff;
				color: rgb(var(--gray-dark));
			}

			@media (max-width: 900px) {
				.filter-grid {
					grid-template-columns: 1fr;
				}

				.homepage {
					padding: 1rem;
					margin-top: 1rem;
				}

				.toggles {
					gap: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="homepage">
			<section>
				<div class="heading">
					<h1>NOWAWyszukaj oferty nieruchomości</h1>
					<p>Ustaw filtry i znajdź mieszkanie, dom lub lokal w wybranej lokalizacji.</p>
				</div>

				<form>
					<div class="filter-grid">
						<div class="field">
							<label for="offerType">Typ oferty</label>
							<select id="offerType" name="offerType">
								<option>Sprzedaż</option>
								<option>Wynajem</option>
							</select>
						</div>
						<div class="field">
							<label for="propertyType">Rodzaj nieruchomości</label>
							<select id="propertyType" name="propertyType">
								<option>Mieszkalny</option>
								<option>Dom</option>
								<option>Lokal użytkowy</option>
							</select>
						</div>
						<div class="field">
							<label for="district">Miasto / dzielnica</label>
							<input id="district" name="district" placeholder="np. Warszawa, Mokotów" />
						</div>

						<div class="field">
							<label for="priceMin">Cena od (PLN)</label>
							<input id="priceMin" name="priceMin" placeholder="np. 550000" />
						</div>
						<div class="field">
							<label for="priceMax">Cena do (PLN)</label>
							<input id="priceMax" name="priceMax" placeholder="np. 1200000" />
						</div>
						<div class="field">
							<label for="area">Powierzchnia min (m2)</label>
							<input id="area" name="area" placeholder="np. 45" />
						</div>

						<div class="field">
							<label for="rooms">Liczba pokoi</label>
							<select id="rooms" name="rooms">
								<option>2+</option>
								<option>3+</option>
								<option>4+</option>
							</select>
						</div>
						<div class="field">
							<label for="market">Rynek</label>
							<select id="market" name="market">
								<option>Pierwotny i wtórny</option>
								<option>Pierwotny</option>
								<option>Wtórny</option>
							</select>
						</div>
						<div class="field">
							<label for="finish">Wykończenie</label>
							<select id="finish" name="finish">
								<option>Niewykończone</option>
								<option>Do zamieszkania</option>
								<option>Wysoki standard</option>
							</select>
						</div>

						<div class="field">
							<label for="availableFrom">Termin odbioru</label>
							<select id="availableFrom" name="availableFrom">
								<option>Dowolny</option>
								<option>Do 3 miesięcy</option>
								<option>Do 6 miesięcy</option>
							</select>
						</div>
						<div class="field">
							<label for="floor">Piętro</label>
							<input id="floor" name="floor" placeholder="np. 2 - 5" />
						</div>
						<div class="field">
							<label for="year">Rok budowy</label>
							<input id="year" name="year" placeholder="np. 2010" />
						</div>
					</div>

					<div class="quick-filters" aria-label="Szybkie filtry">
						<button class="pill active" type="button">Balkon</button>
						<button class="pill" type="button">Winda</button>
						<button class="pill" type="button">Miejsce postojowe</button>
						<button class="pill" type="button">Ogród</button>
						<button class="pill" type="button">Umeblowanie</button>
					</div>

					<div class="footer-row">
						<div class="toggles">
							<label class="toggle" for="promotedOnly">
								<input id="promotedOnly" type="checkbox" checked />
								Z promocją
							</label>
							<label class="toggle" for="ownerOnly">
								<input id="ownerOnly" type="checkbox" />
								Od właściciela
							</label>
							<label class="toggle" for="forNow">
								<input id="forNow" type="checkbox" />
								Od zaraz
							</label>
						</div>

						<div class="actions">
							<button class="primary" type="submit">Szukaj ofert</button>
							<button class="secondary" type="reset">Wyczyść</button>
						</div>
					</div>
				</form>
			</section>
		</main>
	</body>
</html>
