---
interface Props {
  label: string;
  value: string | number;
  hint: string;
}

const { label, value, hint } = Astro.props;
---

<div class="rounded-[1.75rem] border border-black/8 bg-white/88 px-5 py-5 shadow-[0_18px_40px_rgba(42,33,23,0.06)]">
  <p class="font-primary text-[0.64rem] uppercase tracking-[0.24em] text-[#8a7760]">{label}</p>
  <p class="mt-4 font-primary text-[2rem] font-semibold leading-none text-[#17130f]">{value}</p>
  <p class="mt-3 font-secondary text-sm text-[#6f6254]">{hint}</p>
</div>
