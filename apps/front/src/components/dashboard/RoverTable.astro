---
import StatusLabel from "./StatusLabel.astro";

interface RoverRow {
  name: string;
  subtitle: string;
  model: string;
  status: "available" | "charging" | "queued";
  range: string;
  rate: string;
}

const rovers: RoverRow[] = [
  {
    name: "LNX-204 Pathfinder",
    subtitle: "Last serviced 12h ago",
    model: "Atlas IV",
    status: "available",
    range: "65 km",
    rate: "$4,600",
  },
  {
    name: "AR-17 Surveyor",
    subtitle: "Thermal scan kit",
    model: "Helios II",
    status: "charging",
    range: "54 km",
    rate: "$3,800",
  },
  {
    name: "VX-88 Cargo",
    subtitle: "Heavy lift platform",
    model: "Titan Hauler",
    status: "queued",
    range: "88 km",
    rate: "$6,200",
  },
  {
    name: "MMU-09 Hopper",
    subtitle: "Micro terrain mapper",
    model: "Lumen Scout",
    status: "available",
    range: "42 km",
    rate: "$3,250",
  },
];
---

<div class="flex flex-col flex-1 gap-3 overflow-hidden">
  <!-- Search & Actions -->
  <div class="flex items-center justify-between gap-4 w-full">
    <div class="flex flex-col flex-1 gap-[6px]">
      <div class="flex items-center h-[32px] px-3 py-2 rounded-full bg-[var(--input)] border border-[var(--border)]">
        <span class="font-secondary text-[var(--muted-foreground)] text-[14px] leading-[1.43]">Search rovers</span>
      </div>
    </div>
    <div class="flex gap-3">
      <button class="flex items-center justify-center gap-[6px] h-[32px] px-4 rounded-full bg-[var(--background)] border border-[var(--border)]">
        <span class="font-primary text-[var(--foreground)] text-[11px] font-medium leading-none text-center">Filters</span>
      </button>
      <button class="flex items-center justify-center gap-[6px] h-[32px] px-4 rounded-full bg-[var(--primary)]">
        <span class="font-primary text-[var(--primary-foreground)] text-[11px] font-medium leading-none text-center">Add Listing</span>
      </button>
    </div>
  </div>

  <!-- Table -->
  <div class="flex flex-col flex-1 overflow-hidden">
    <!-- Table Header -->
    <div class="flex items-center w-full px-0 py-2 border-b border-[var(--border)]">
      <div class="flex-1 px-3"><span class="font-secondary text-[var(--foreground)] text-[10px] font-semibold">Rover</span></div>
      <div class="w-[180px] px-3"><span class="font-secondary text-[var(--foreground)] text-[10px] font-semibold">Model</span></div>
      <div class="w-[140px] px-3"><span class="font-secondary text-[var(--foreground)] text-[10px] font-semibold">Status</span></div>
      <div class="w-[140px] px-3"><span class="font-secondary text-[var(--foreground)] text-[10px] font-semibold">Range</span></div>
      <div class="w-[140px] px-3"><span class="font-secondary text-[var(--foreground)] text-[10px] font-semibold">Rate / day</span></div>
    </div>

    <!-- Table Body -->
    <div class="flex flex-col flex-1 overflow-auto">
      {rovers.map((rover) => (
        <div class="flex items-center w-full px-0 py-2.5 border-b border-[var(--border)]">
          <div class="flex flex-col flex-1 px-3">
            <span class="font-primary text-[var(--foreground)] text-[11px] font-semibold">{rover.name}</span>
            <span class="font-secondary text-[var(--muted-foreground)] text-[9px]">{rover.subtitle}</span>
          </div>
          <div class="w-[180px] px-3">
            <span class="font-secondary text-[var(--foreground)] text-[10px]">{rover.model}</span>
          </div>
          <div class="w-[140px] px-3">
            <StatusLabel status={rover.status} />
          </div>
          <div class="w-[140px] px-3">
            <span class="font-secondary text-[var(--foreground)] text-[10px]">{rover.range}</span>
          </div>
          <div class="w-[140px] px-3">
            <span class="font-primary text-[var(--foreground)] text-[11px] font-semibold">{rover.rate}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Table Footer -->
    <div class="flex items-center justify-between w-full pt-2">
      <span class="font-secondary text-[var(--muted-foreground)] text-[10px] leading-[1.43]">Showing 6 available rovers</span>
      <div class="flex items-center gap-2">
        <button class="flex items-center justify-center h-[24px] px-2.5 rounded-full text-[var(--muted-foreground)]">
          <span class="font-primary text-[10px] font-medium leading-none text-center">Previous</span>
        </button>
        <a href="#" class="font-primary text-[10px] text-[#4b66ff] underline">1</a>
        <button class="flex items-center justify-center h-[24px] px-2.5 rounded-full text-[var(--foreground)]">
          <span class="font-primary text-[10px] font-medium leading-none text-center">Next</span>
        </button>
      </div>
    </div>
  </div>
</div>
