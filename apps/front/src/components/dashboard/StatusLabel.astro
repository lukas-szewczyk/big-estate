---
interface Props {
  status: "draft" | "active" | "sold" | "expired";
}

const { status } = Astro.props;

const config = {
  draft: {
    text: "Szkic",
    className: "bg-[#f3e5d7] text-[#8b5a2b]",
  },
  active: {
    text: "Aktywna",
    className: "bg-[#ddefdf] text-[#2f6e45]",
  },
  sold: {
    text: "Sprzedana",
    className: "bg-[#e4ebff] text-[#3557b7]",
  },
  expired: {
    text: "Wygasła",
    className: "bg-[#ece7df] text-[#625648]",
  },
} as const;

const item = config[status];
---

<span class:list={["inline-flex items-center rounded-full px-2.5 py-1 font-primary text-[0.62rem] uppercase tracking-[0.18em]", item.className]}>
  {item.text}
</span>
