---
import type { SessionUser } from "../../lib/auth";

interface Props {
  currentPath: string;
  user: SessionUser;
}

const { currentPath, user } = Astro.props;
const normalizedPath =
  currentPath.length > 1 && currentPath.endsWith("/")
    ? currentPath.slice(0, -1)
    : currentPath;

const navItems = [
  { href: "/dashboard", label: "Przegląd" },
  { href: "/dashboard/oferty", label: "Moje oferty" },
  { href: "/dashboard/oferty/nowa", label: "Nowa oferta" },
];

function businessRoleLabel(role: SessionUser["business_role"]) {
  switch (role) {
    case "agent":
      return "Agent";
    case "developer":
      return "Deweloper";
    case "owner":
      return "Właściciel";
    default:
      return "Kupujący";
  }
}
---

<aside class="flex min-h-screen w-full max-w-[17rem] flex-col border-r border-black/10 bg-white/70 px-4 py-5 backdrop-blur-xl">
  <a href="/" class="inline-flex items-center gap-3 px-2 py-2 text-[#1d1711]">
    <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-[#19150f] font-primary text-xs text-white">
      LU
    </span>
    <span>
      <span class="block font-primary text-[0.72rem] uppercase tracking-[0.28em] text-[#8a7760]">Workspace</span>
      <span class="block font-secondary text-base font-semibold">Seller</span>
    </span>
  </a>

  <div class="mt-8 space-y-1">
    {navItems.map((item) => {
      const active =
        normalizedPath === item.href ||
        (item.href !== "/dashboard" && normalizedPath.startsWith(item.href));

      return (
        <a
          href={item.href}
          class:list={[
            "flex items-center justify-between rounded-2xl px-3 py-3 font-secondary text-sm transition-all duration-200",
            active
              ? "bg-[#19150f] text-white shadow-[0_18px_30px_rgba(25,21,15,0.16)]"
              : "text-[#3f3529] hover:bg-[#f2ebe1]",
          ]}
        >
          <span>{item.label}</span>
          {active && <span class="font-primary text-[0.62rem] uppercase tracking-[0.24em] text-white/70">LIVE</span>}
        </a>
      );
    })}
  </div>

  <div class="mt-8 rounded-[1.6rem] border border-black/8 bg-[#f6efe4] px-4 py-4">
    <p class="font-primary text-[0.64rem] uppercase tracking-[0.24em] text-[#8a7760]">Rola</p>
    <p class="mt-2 font-secondary text-sm font-semibold text-[#211a13]">{businessRoleLabel(user.business_role)}</p>
    <p class="mt-1 font-secondary text-xs text-[#6e6255]">
      {user.is_verified ? "Profil zweryfikowany" : "Profil oczekuje na weryfikację"}
    </p>
    {user.business_role === "agent" && !user.agency_id && (
      <p class="mt-3 font-secondary text-xs text-[#7a4f1c]">Dodaj agencję, aby publikować oferty.</p>
    )}
  </div>

  <div class="mt-auto rounded-[1.6rem] border border-black/8 bg-white px-4 py-4 shadow-[0_10px_30px_rgba(37,28,19,0.06)]">
    <p class="font-secondary text-sm font-semibold text-[#211a13]">{user.email}</p>
    <p class="mt-1 font-secondary text-xs text-[#7b6f62]">Panel sprzedającego nieruchomości</p>
  </div>
</aside>
