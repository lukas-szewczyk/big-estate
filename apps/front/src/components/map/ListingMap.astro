---
import "maplibre-gl/dist/maplibre-gl.css";

interface Props {
  apiBaseUrl?: string;
  class?: string;
  initialCenter?: [number, number];
  initialBounds?: [number, number, number, number] | null;
  initialZoom?: number;
  isAuthenticated?: boolean;
  pmtilesUrl?: string;
  listingsApiUrl?: string;
  enableDrawToSearch?: boolean;
}

const {
  apiBaseUrl = "http://localhost:3000",
  class: className,
  initialCenter = [19.1451, 51.9194],
  initialBounds = null,
  initialZoom = 6,
  isAuthenticated = false,
  pmtilesUrl = "https://pub-bfaa61c41d364f489c3ef9b268baf004.r2.dev/poland.pmtiles",
  listingsApiUrl = "/api/listings",
  enableDrawToSearch = false,
} = Astro.props;
---

<div
  class:list={["listing-map", className]}
  data-listing-map
  data-api-base-url={apiBaseUrl}
  data-authenticated={isAuthenticated ? "true" : "false"}
  data-initial-center={JSON.stringify(initialCenter)}
  data-initial-bounds={initialBounds ? JSON.stringify(initialBounds) : undefined}
  data-initial-zoom={String(initialZoom)}
  data-pmtiles-url={pmtilesUrl}
  data-listings-api-url={listingsApiUrl}
  data-enable-draw-to-search={enableDrawToSearch ? "true" : "false"}
  data-status="idle"
>
  <section class="listing-map__map-pane">
    <div class="listing-map__canvas" data-listing-map-canvas></div>
    {
      enableDrawToSearch && (
        <>
          <div class="listing-map__controls" data-listing-map-controls>
            <button
              type="button"
              class="listing-map__control-button"
              data-draw-toggle
              aria-pressed="false"
            >
              Rysuj obszar
            </button>
            <button
              type="button"
              class="listing-map__control-button"
              data-clear-drawing
              disabled
            >
              Wyczyść obszar
            </button>
          </div>
          <div
            class="listing-map__drawing-overlay"
            data-listing-map-drawing-overlay
            hidden
            aria-hidden="true"
          ></div>
        </>
      )
    }
    <div class="listing-map__status" data-listing-map-status hidden></div>
  </section>

  <aside class="listing-map__list-pane" aria-label="Oferty w aktualnym widoku mapy">
    <div class="listing-map__list-header">
      <p class="listing-map__list-eyebrow">Na mapie</p>
      <h2 class="listing-map__list-title">Oferty w zasięgu</h2>
      <p class="listing-map__list-summary" data-listing-list-summary>
        Przesuń mapę, aby wczytać oferty w tej okolicy.
      </p>
    </div>

    <div class="listing-map__list-scroll">
      <div class="listing-map__empty-state" data-listing-list-empty hidden>
        Brak ofert w tym obszarze
      </div>
      <div class="listing-map__cards" data-listing-list-items></div>
    </div>
  </aside>

  <dialog class="listing-map__wishlist-dialog" data-wishlist-dialog>
    <form method="dialog" class="listing-map__wishlist-dialog-card">
      <div class="listing-map__wishlist-dialog-header">
        <div>
          <p class="listing-map__list-eyebrow">Wishlista</p>
          <h3 class="listing-map__list-title">Zapisz ofertę</h3>
        </div>
        <button
          type="submit"
          class="listing-map__wishlist-dialog-close"
          aria-label="Zamknij okno wishlisty"
        >
          ×
        </button>
      </div>

      <p class="listing-map__list-summary" data-wishlist-dialog-summary>
        Wybierz listy, do których chcesz dodać ofertę.
      </p>

      <div class="listing-map__wishlist-options" data-wishlist-options></div>

      <div class="listing-map__wishlist-create">
        <input
          type="text"
          class="listing-map__wishlist-input"
          placeholder="Nazwa nowej wishlisty"
          data-wishlist-new-name
        />
        <select class="listing-map__wishlist-input" data-wishlist-new-color>
          <option value="sand">Piaskowy</option>
          <option value="amber">Bursztyn</option>
          <option value="rose">Róż</option>
          <option value="plum">Śliwka</option>
          <option value="sky">Błękit</option>
          <option value="teal">Morski</option>
          <option value="sage">Szałwia</option>
          <option value="slate">Łupek</option>
        </select>
        <button type="button" class="listing-map__wishlist-create-button" data-wishlist-create-button>
          Utwórz nową listę
        </button>
      </div>

      <p class="listing-map__wishlist-dialog-note" data-wishlist-dialog-note hidden></p>
    </form>
  </dialog>
</div>

<script>
  import { mountListingMap } from "../../scripts/listing-map";

  const mountedMaps = new WeakMap();

  const setupListingMaps = () => {
    document.querySelectorAll("[data-listing-map]").forEach((node) => {
      if (!(node instanceof HTMLElement) || mountedMaps.has(node)) {
        return;
      }

      const cleanup = mountListingMap(node);
      mountedMaps.set(node, cleanup);
    });
  };

  const cleanupListingMaps = () => {
    document.querySelectorAll("[data-listing-map]").forEach((node) => {
      if (!(node instanceof HTMLElement)) {
        return;
      }

      const cleanup = mountedMaps.get(node);
      if (!cleanup) {
        return;
      }

      cleanup();
      mountedMaps.delete(node);
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", setupListingMaps, {
      once: true,
    });
  } else {
    setupListingMaps();
  }

  document.addEventListener("astro:page-load", setupListingMaps);
  document.addEventListener("astro:after-swap", setupListingMaps);
  document.addEventListener("astro:before-swap", cleanupListingMaps);
  window.addEventListener("pagehide", cleanupListingMaps, { once: true });
</script>

<style>
  .listing-map {
    display: grid;
    grid-template-rows: minmax(25rem, 60vh) minmax(0, 1fr);
    width: 100%;
    height: 100%;
    min-height: 100%;
    overflow: hidden;
    background: #f7f2ea;
  }

  .listing-map__map-pane {
    position: relative;
    min-height: 25rem;
  }

  .listing-map__canvas {
    position: absolute;
    inset: 0;
  }

  .listing-map__list-pane {
    display: flex;
    min-height: 0;
    flex-direction: column;
    border-top: 1px solid rgb(48 35 38 / 0.08);
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.94), rgb(248 243 235 / 0.98)),
      linear-gradient(180deg, #f8f3eb 0%, #f2eadf 100%);
  }

  .listing-map__list-header {
    display: grid;
    gap: 0.35rem;
    padding: 1.25rem 1.25rem 0.9rem;
    border-bottom: 1px solid rgb(48 35 38 / 0.08);
    background: rgb(255 255 255 / 0.72);
    backdrop-filter: blur(10px);
  }

  .listing-map__list-eyebrow {
    margin: 0;
    color: #8a7760;
    font: 600 0.7rem/1 "JetBrains Mono", monospace;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .listing-map__list-title {
    margin: 0;
    color: #201913;
    font: 600 1.2rem/1.15 "Geist Variable", sans-serif;
  }

  .listing-map__list-summary {
    margin: 0;
    color: #665c50;
    font: 0.92rem/1.45 "Geist Variable", sans-serif;
  }

  .listing-map__list-scroll {
    flex: 1;
    min-height: 0;
    overflow: auto;
    padding: 1rem 1rem 1.25rem;
  }

  .listing-map__cards {
    display: grid;
    gap: 0.9rem;
  }

  .listing-map__wishlist-dialog {
    border: 0;
    padding: 0;
    background: transparent;
  }

  .listing-map__wishlist-dialog::backdrop {
    background: rgba(25, 21, 15, 0.3);
    backdrop-filter: blur(6px);
  }

  .listing-map__wishlist-dialog-card {
    width: min(30rem, calc(100vw - 2rem));
    display: grid;
    gap: 1rem;
    border-radius: 1.75rem;
    border: 1px solid rgb(48 35 38 / 0.08);
    background: rgb(255 251 246 / 0.98);
    padding: 1.25rem;
    box-shadow: 0 24px 50px rgb(42 33 23 / 0.18);
  }

  .listing-map__wishlist-dialog[data-busy="true"] .listing-map__wishlist-dialog-card {
    opacity: 0.82;
  }

  .listing-map__wishlist-dialog-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .listing-map__wishlist-dialog-close {
    border: 1px solid rgb(48 35 38 / 0.08);
    border-radius: 999px;
    width: 2rem;
    height: 2rem;
    background: white;
    color: #2d251d;
    font-size: 1.1rem;
  }

  .listing-map__wishlist-options {
    display: grid;
    gap: 0.65rem;
    max-height: 14rem;
    overflow: auto;
  }

  .listing-map__wishlist-option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border: 1px solid rgb(48 35 38 / 0.08);
    border-radius: 1rem;
    background: #fbf8f4;
    padding: 0.85rem 0.95rem;
  }

  .listing-map__wishlist-option-main {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  .listing-map__wishlist-swatch {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 999px;
    flex-shrink: 0;
  }

  .listing-map__wishlist-option-label {
    margin: 0;
    color: #201913;
    font: 600 0.92rem/1.2 "Geist Variable", sans-serif;
  }

  .listing-map__wishlist-option-meta {
    margin: 0.2rem 0 0;
    color: #665c50;
    font: 0.78rem/1.3 "Geist Variable", sans-serif;
  }

  .listing-map__wishlist-toggle {
    border: 1px solid rgb(48 35 38 / 0.1);
    border-radius: 999px;
    background: white;
    color: #2d251d;
    font: 600 0.78rem/1 "Geist Variable", sans-serif;
    padding: 0.55rem 0.85rem;
  }

  .listing-map__wishlist-toggle[data-active="true"] {
    background: #201913;
    color: #fffaf4;
  }

  .listing-map__wishlist-toggle:disabled,
  .listing-map__wishlist-create-button:disabled {
    cursor: progress;
    opacity: 0.6;
  }

  .listing-map__wishlist-create {
    display: grid;
    gap: 0.65rem;
  }

  .listing-map__wishlist-input {
    width: 100%;
    border: 1px solid rgb(48 35 38 / 0.1);
    border-radius: 1rem;
    background: white;
    color: #201913;
    font: 0.92rem/1.2 "Geist Variable", sans-serif;
    padding: 0.85rem 1rem;
  }

  .listing-map__wishlist-create-button {
    border: 0;
    border-radius: 999px;
    background: #201913;
    color: #fffaf4;
    font: 600 0.84rem/1 "Geist Variable", sans-serif;
    padding: 0.8rem 1rem;
  }

  .listing-map__wishlist-dialog-note {
    margin: 0;
    color: #7a4f1c;
    font: 0.8rem/1.4 "Geist Variable", sans-serif;
  }

  .listing-map__empty-state {
    border: 1px dashed rgb(138 119 96 / 0.28);
    border-radius: 1.25rem;
    background: rgb(255 255 255 / 0.85);
    color: #65594c;
    font: 500 0.95rem/1.5 "Geist Variable", sans-serif;
    padding: 1.25rem;
    text-align: center;
  }

  .listing-map__status {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 2;
    max-width: min(22rem, calc(100% - 2rem));
    border: 1px solid rgb(134 116 89 / 0.2);
    border-radius: 999px;
    background: rgb(255 250 244 / 0.97);
    color: #5f503d;
    font: 500 0.8rem/1.1 "Geist Variable", sans-serif;
    letter-spacing: 0.01em;
    padding: 0.7rem 0.95rem;
    backdrop-filter: blur(10px);
    box-shadow: 0 14px 30px rgb(73 57 37 / 0.14);
  }

  .listing-map__controls {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 3;
    display: flex;
    gap: 0.65rem;
    flex-wrap: wrap;
    justify-content: flex-end;
    max-width: min(26rem, calc(100% - 2rem));
  }

  .listing-map__control-button {
    border: 1px solid rgb(128 112 115 / 0.14);
    border-radius: 999px;
    background: rgb(255 250 244 / 0.97);
    color: #2d251d;
    font: 600 0.85rem/1 "Geist Variable", sans-serif;
    padding: 0.78rem 1rem;
    box-shadow: 0 12px 28px rgb(50 39 41 / 0.12);
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      color 180ms ease,
      border-color 180ms ease;
  }

  .listing-map__control-button:hover:not(:disabled) {
    transform: translateY(-1px);
    background: rgb(255 247 238);
  }

  .listing-map__control-button:focus-visible {
    outline: 3px solid rgb(138 119 96 / 0.26);
    outline-offset: 2px;
  }

  .listing-map__control-button[data-active="true"] {
    border-color: rgb(91 74 46 / 0.24);
    background: #201913;
    color: #fffaf4;
  }

  .listing-map__control-button:disabled {
    cursor: not-allowed;
    opacity: 0.58;
    transform: none;
  }

  .listing-map__drawing-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    cursor: crosshair;
    touch-action: none;
  }

  .listing-map :global(.listing-map__card) {
    display: grid;
    gap: 0.65rem;
    width: 100%;
    border: 1px solid rgb(48 35 38 / 0.08);
    border-radius: 1.2rem;
    background: rgb(255 255 255 / 0.92);
    padding: 1rem;
    text-align: left;
    cursor: pointer;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      background-color 180ms ease;
    box-shadow: 0 12px 32px rgb(60 43 46 / 0.08);
    position: relative;
  }

  .listing-map :global(.listing-map__card:hover) {
    transform: translateY(-1px);
    border-color: rgb(138 119 96 / 0.34);
    box-shadow: 0 20px 38px rgb(60 43 46 / 0.12);
  }

  .listing-map :global(.listing-map__card:focus-visible) {
    outline: 3px solid rgb(138 119 96 / 0.26);
    outline-offset: 2px;
  }

  .listing-map :global(.listing-map__card.is-active) {
    border-color: rgb(178 149 110 / 0.5);
    background: linear-gradient(180deg, #fbf5eb 0%, #ffffff 100%);
    box-shadow: 0 22px 40px rgb(92 72 44 / 0.14);
  }

  .listing-map :global(.listing-map__card-eyebrow) {
    color: #8a7760;
    font: 600 0.68rem/1 "JetBrains Mono", monospace;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .listing-map :global(.listing-map__card-title) {
    margin: 0;
    color: #251d1f;
    font: 600 1rem/1.25 "Geist Variable", sans-serif;
  }

  .listing-map :global(.listing-map__card-meta) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: #3b2f32;
    font: 600 0.95rem/1.2 "Geist Variable", sans-serif;
  }

  .listing-map :global(.listing-map__card-location) {
    color: #6a5f51;
    font: 0.86rem/1.45 "Geist Variable", sans-serif;
  }

  .listing-map :global(.listing-map__card-save) {
    position: absolute;
    top: 0.8rem;
    right: 0.8rem;
    border: 1px solid rgb(48 35 38 / 0.08);
    background: white;
    color: #8f5f67;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
  }

  .listing-map :global(.listing-map__card-save[data-active="true"]) {
    background: #8f5f67;
    color: white;
    border-color: #8f5f67;
  }

  .listing-map :global(.listing-map__price-marker) {
    border: 1px solid rgb(48 35 38 / 0.14);
    background: rgb(255 255 255 / 0.96);
    color: #1f1812;
    border-radius: 999px;
    padding: 0.48rem 0.72rem;
    box-shadow: 0 10px 22px rgb(42 33 23 / 0.16);
    font: 700 0.76rem/1 "Geist Variable", sans-serif;
    letter-spacing: -0.01em;
    white-space: nowrap;
    backdrop-filter: blur(6px);
  }

  .listing-map :global(.listing-map__price-marker[data-saved="true"]) {
    color: #ffffff;
  }

  .listing-map :global(.maplibregl-popup-content) {
    padding: 0;
    overflow: hidden;
    border-radius: 1rem;
    box-shadow: 0 24px 48px rgb(33 25 26 / 0.18);
  }

  .listing-map :global(.maplibregl-popup-tip) {
    border-top-color: white;
  }

  .listing-map :global(.maplibregl-ctrl-group) {
    border: 1px solid rgb(128 112 115 / 0.14);
    box-shadow: 0 12px 28px rgb(50 39 41 / 0.12);
  }

  .listing-map :global(.listing-popup) {
    width: min(18rem, 78vw);
    background: white;
  }

  .listing-map :global(.listing-popup__image) {
    display: block;
    width: 100%;
    height: 8.5rem;
    object-fit: cover;
    background: #f4eeea;
  }

  .listing-map :global(.listing-popup__body) {
    display: grid;
    gap: 0.5rem;
    padding: 1rem;
  }

  .listing-map :global(.listing-popup__eyebrow) {
    color: #8a7760;
    font: 600 0.72rem/1 "JetBrains Mono", monospace;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .listing-map :global(.listing-popup__title) {
    margin: 0;
    color: #251d1f;
    font: 600 1rem/1.2 "Geist Variable", sans-serif;
  }

  .listing-map :global(.listing-popup__meta) {
    margin: 0;
    color: #675b4f;
    font: 0.88rem/1.45 "Geist Variable", sans-serif;
  }

  .listing-map :global(.listing-popup__details) {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: #312720;
    font: 500 0.88rem/1.2 "Geist Variable", sans-serif;
  }

  .listing-map :global(.listing-popup__actions) {
    display: flex;
    justify-content: flex-end;
  }

  .listing-map :global(.listing-popup__save) {
    border: 1px solid rgb(48 35 38 / 0.08);
    background: white;
    color: #8f5f67;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
  }

  .listing-map :global(.listing-popup__save[data-active="true"]) {
    color: white;
  }

  @media (min-width: 960px) {
    .listing-map {
      grid-template-columns: minmax(0, 1fr) minmax(19.5rem, 24rem);
      grid-template-rows: minmax(0, 1fr);
    }

    .listing-map__list-pane {
      border-top: 0;
      border-left: 1px solid rgb(48 35 38 / 0.08);
    }

    .listing-map__list-header {
      padding: 1.35rem 1.35rem 1rem;
    }

    .listing-map__list-scroll {
      padding: 1rem 1.1rem 1.35rem;
    }
  }
</style>
