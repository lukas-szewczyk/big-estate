{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "env": ["PUBLIC_API_BASE_URL", "SITE_URL"],
      "outputs": ["dist/**"]
    },
    "check-types": {
      "outputs": [".astro/**", "worker-configuration.d.ts"]
    },
    "deploy": {
      "env": ["CLOUDFLARE_ACCOUNT_ID", "CLOUDFLARE_API_TOKEN", "SITE_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
